        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Format Supabase query results into MCP JSON-RPC 2.0 response\nconst items = $input.all();\nconst requestData = $('Parse MCP Request').first().json;\n\n// Extract the query results from Supabase\nconst queryResults = items.map(item => item.json);\n\n// Build MCP JSON-RPC 2.0 response\nconst mcpResponse = {\n  jsonrpc: \"2.0\",\n  id: requestData.id || 1,\n  result: {\n    data: queryResults\n  }\n};\n\nreturn [{ json: mcpResponse }];"
      },
