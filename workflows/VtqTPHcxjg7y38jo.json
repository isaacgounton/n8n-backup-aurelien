    {
      "parameters": {
        "jsCode": "// Parse incoming MCP request (JSON-RPC 2.0 format)\nconst body = $input.item.json.body;\n\n// Extract JSON-RPC fields\nconst jsonrpc = body.jsonrpc || '2.0';\nconst method = body.method;\nconst params = body.params || {};\nconst id = body.id;\n\n// Parse MCP method to extract operation details\n// Expected format: \"database.operation\" or similar\nconst methodParts = method ? method.split('.') : [];\nconst operation = methodParts[methodParts.length - 1]; // e.g., 'list', 'get', 'search', 'insert', 'update', 'delete'\n\n// Extract parameters\nconst tableName = params.table || params.tableName || '';\nconst filters = params.filters || params.where || {};\nconst data = params.data || {};\nconst columns = params.columns || params.select || '*';\nconst limit = params.limit || 100;\nconst offset = params.offset || 0;\nconst orderBy = params.orderBy || params.order || '';\n\n// Return structured data for Supabase node\nreturn [\n  {\n    json: {\n      // Original JSON-RPC fields\n      jsonrpc: jsonrpc,\n      requestId: id,\n      method: method,\n      \n      // Parsed operation details\n      operation: operation,\n      tableName: tableName,\n      filters: filters,\n      data: data,\n      columns: columns,\n      limit: limit,\n      offset: offset,\n      orderBy: orderBy,\n      \n      // Full params for reference\n      params: params\n    }\n  }\n];"
      },
      "id": "6d30312c-7db0-4ed9-841c-d6b9f96c603b",
      "name": "Parse MCP Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        1104
      ]
    },
    {
      "parameters": {
        "operation": "getAll",
        "tableId": "={{ $json.tableName }}",
        "matchType": "allFilters",
        "filters": {
          "conditions": []
        }
      },
      "id": "80d2d23c-8027-4f4d-9492-c4181d89239b",
      "name": "Query Supabase Database",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        448,
