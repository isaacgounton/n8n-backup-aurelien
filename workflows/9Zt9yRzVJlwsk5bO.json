    {
      "parameters": {
        "jsCode": "// Format tasks into HTML email template\nconst items = $input.all();\n\nif (items.length === 0) {\n  return [{\n    json: {\n      htmlBody: '<p>No active priority tasks for today.</p>',\n      taskCount: 0\n    }\n  }];\n}\n\n// Build HTML table\nlet htmlBody = `\n<h2>Daily Task Digest</h2>\n<p>You have ${items.length} active priority task(s):</p>\n<table border=\"1\" cellpadding=\"8\" cellspacing=\"0\" style=\"border-collapse: collapse; width: 100%; font-family: Arial, sans-serif;\">\n  <thead>\n    <tr style=\"background-color: #4CAF50; color: white;\">\n      <th>Task Name</th>\n      <th>Property</th>\n      <th>Assigned To</th>\n      <th>Status</th>\n      <th>Priority</th>\n      <th>Due Date</th>\n      <th>Notes</th>\n    </tr>\n  </thead>\n  <tbody>\n`;\n\n// Add each task as a row\nfor (const item of items) {\n  const task = item.json;\n  const priorityColor = task.priority === 'High' ? '#ff4444' : task.priority === 'Medium' ? '#ffaa00' : '#44ff44';\n  \n  htmlBody += `\n    <tr>\n      <td>${task.taskName || ''}</td>\n      <td>${task.property || ''}</td>\n      <td>${task.assignedTo || ''}</td>\n      <td>${task.status || ''}</td>\n      <td style=\"color: ${priorityColor}; font-weight: bold;\">${task.priority || ''}</td>\n      <td>${task.dueDate || ''}</td>\n      <td>${task.notes || ''}</td>\n    </tr>\n  `;\n}\n\nhtmlBody += `\n  </tbody>\n</table>\n<p style=\"margin-top: 20px; color: #666;\">This is your automated daily task digest.</p>\n`;\n\nreturn [{\n  json: {\n    htmlBody: htmlBody,\n    taskCount: items.length\n  }\n}];"
      },
