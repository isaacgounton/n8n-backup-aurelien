    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Parse email body for task management commands\nconst emailBody = $input.item.json.body || $input.item.json.snippet || '';\nconst subject = $input.item.json.subject || '';\n\n// Initialize result object\nconst result = {\n  commandType: null,\n  taskName: null,\n  status: null,\n  priority: null,\n  assignedTo: null,\n  dueDate: null,\n  notes: null\n};\n\n// Check if this is a NEW TASK command\nif (emailBody.match(/NEW TASK:/i) || subject.match(/NEW TASK:/i)) {\n  result.commandType = 'create';\n  \n  // Extract task name (text after NEW TASK:)\n  const taskNameMatch = emailBody.match(/NEW TASK:\\s*([^\\n]+)/i) || subject.match(/NEW TASK:\\s*([^\\n]+)/i);\n  if (taskNameMatch) {\n    result.taskName = taskNameMatch[1].trim();\n  }\n} else {\n  // This is an UPDATE command\n  result.commandType = 'update';\n  \n  // Extract task name from subject or first line\n  const taskNameMatch = subject.match(/(?:RE:|FW:|Update)\\s*:?\\s*(.+)/i) || emailBody.match(/^([^\\n]+)/i);\n  if (taskNameMatch) {\n    result.taskName = taskNameMatch[1].trim();\n  }\n}\n\n// Extract status (e.g., \"status: done\", \"status:in progress\")\nconst statusMatch = emailBody.match(/status:\\s*([^\\n,]+)/i);\nif (statusMatch) {\n  result.status = statusMatch[1].trim();\n}\n\n// Extract priority (e.g., \"priority: high\", \"priority:low\")\nconst priorityMatch = emailBody.match(/priority:\\s*([^\\n,]+)/i);\nif (priorityMatch) {\n  result.priority = priorityMatch[1].trim();\n}\n\n// Extract assigned to (e.g., \"assigned to: John\", \"assigned:Jane\")\nconst assignedMatch = emailBody.match(/assigned(?:\\s+to)?:\\s*([^\\n,]+)/i);\nif (assignedMatch) {\n  result.assignedTo = assignedMatch[1].trim();\n}\n\n// Extract due date (e.g., \"due: 2024-01-15\", \"due date: tomorrow\")\nconst dueDateMatch = emailBody.match(/due(?:\\s+date)?:\\s*([^\\n,]+)/i);\nif (dueDateMatch) {\n  result.dueDate = dueDateMatch[1].trim();\n}\n\n// Extract notes (e.g., \"notes: some text\", everything after \"notes:\")\nconst notesMatch = emailBody.match(/notes:\\s*([\\s\\S]*?)(?=\\n(?:status|priority|assigned|due)|$)/i);\nif (notesMatch) {\n  result.notes = notesMatch[1].trim();\n}\n\n// Return the parsed command\nreturn {\n  json: {\n    ...result,\n    originalSubject: subject,\n    originalBody: emailBody,\n    parsedAt: new Date().toISOString()\n  }\n};"
      },
