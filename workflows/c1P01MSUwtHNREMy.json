    {
      "parameters": {
        "jsCode": "// grab your merged data\nconst d = items[0].json;\n\n// helper to pick points\nfunction pick(val, thresholds){\n  for(const [limit,pts] of thresholds){\n    if(val >= limit) return pts;\n  }\n  return thresholds[thresholds.length-1][1];\n}\n\n// 1) Income → Rent Ratio (30%)\nconst ratio = Number(d.income) / Number(d.expected_rent);\nconst ratioPts = ratio >= 3   ? 10\n               : ratio >= 2.5 ? 8\n               : ratio >= 2   ? 6\n               :                2;\n\n// 2) Credit Score (20%)\nconst cs = Number(d.credit_score);\nconst csPts = cs >= 700 ? 10\n             : cs >= 650 ? 7\n             : cs >= 600 ? 4\n             :             1;\n\n// 3) Employment Tenure in months (15%)\nconst tenure = Number(d.employment_months);\nconst etPts = tenure >= 24 ? 10\n            : tenure >= 12 ? 7\n            : tenure >= 6  ? 4\n            :                1;\n\n// 4) Rental History (15%)\nlet rhPts = 10;\nif(d.rental_history?.includes(\"multiple evictions\")) rhPts = 0;\nelse if(d.rental_history?.includes(\"one eviction\"))    rhPts = 5;\n\n// 5) Pets (5%)\nconst pet = d.pets?.toLowerCase() || \"\";\nconst petPts = pet.includes(\"no\")   ? 10\n             : pet.includes(\"small\")? 7\n             : pet.includes(\"large\")? 4\n             :                          2;\n\n// 6) Smoking (5%)\nconst smoke = d.smoking?.toLowerCase() || \"\";\nconst smokePts = smoke.includes(\"non\")    ? 10\n               : smoke.includes(\"outside\")? 5\n               :                              0;\n\n// 7) Move-in Flexibility (10%)\nconst wanted = new Date(d.desired_move_in);\nconst actual = new Date(d.move_in_date);\nconst diffDays = Math.abs((actual - wanted)/(1000*60*60*24));\nconst mfPts = diffDays <= 0  ? 10\n            : diffDays <= 7  ? 7\n            : diffDays <= 14 ? 4\n            :                  2;\n\n// weights\nconst w = {\n  ratio: 0.30, cs: 0.20, et: 0.15, rh: 0.15,\n  pets: 0.05, smoke: 0.05, mf: 0.10\n};\n\n// total score (out of 10)\nconst total =\n  ratioPts * w.ratio +\n  csPts    * w.cs    +\n  etPts    * w.et    +\n  rhPts    * w.rh    +\n  petPts   * w.pets  +\n  smokePts * w.smoke +\n  mfPts    * w.mf;\n\n// build the rubric text\nconst rubric = `\nIncome → Rent Ratio: ${ratioPts} pts\nCredit Score: ${csPts} pts\nEmployment Tenure: ${etPts} pts\nRental History: ${rhPts} pts\nPets: ${petPts} pts\nSmoking: ${smokePts} pts\nMove-in Flexibility: ${mfPts} pts\n\n⭐️ **Total Fit Score**: ${total.toFixed(1)}/10\n`.trim();\n\n// return merged data + new fields\nreturn [{\n  json: {\n    ...d,\n    score: total.toFixed(1),\n    rubric\n  }\n}];\n"
      },
