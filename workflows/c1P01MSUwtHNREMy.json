    {
      "parameters": {
        "jsCode": "// Grab the latest ChatGPT output\nconst extracted = $node[\"Message a model\"].json;\n// Grab the email subject so we can derive category\nconst subject   = $node[\"Gmail Trigger\"].json[\"subject\"] || \"\";\n\n// If ChatGPT didn’t extract category, infer from subject\nconst category = extracted.category\n  || (subject.match(/2BR Mini Home/i) ? \"2BR Mini Home\" : \"\")\n  || \"\";\n\n// Build a single merged object\nconst merged = {\n  email:        extracted.email       || \"\",\n  full_name:    extracted.full_name   || \"\",\n  phone:        extracted.phone       || \"\",\n  income:       extracted.income      || \"\",\n  employer:     extracted.employer    || \"\",\n  move_in_date: extracted.move_in_date|| \"\",\n  occupants:    extracted.occupants   || \"\",\n  pets:         extracted.pets        || \"\",\n  reason:       extracted.reason      || \"\",\n  category:     category\n};\n\nreturn [{ json: merged }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
